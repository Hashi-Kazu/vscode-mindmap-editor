{
  "name": "vscode-mindmap-editor",
  "displayName": "Markdown Mind Map Editor",
  "description": "Markdownの見出し構造をインタラクティブなマインドマップとして表示・編集するVS Code拡張機能",
  "version": "1.5.0",
  "publisher": "Hashi-Kazu",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hashi-Kazu/vscode-mindmap-editor"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Visualization"],
  "keywords": ["markdown", "mindmap", "mind map", "editor", "visualization"],
  "activationEvents": ["onLanguage:markdown"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mindmap.openMindMap",
        "title": "マインドマップとして開く",
        "category": "Mind Map",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mindmap.openMindMap",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "mindmap.openMindMap",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mindmap.openMindMap",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
