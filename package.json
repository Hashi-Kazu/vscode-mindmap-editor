{
  "name": "vscode-mindmap-editor",
  "displayName": "Markdown マインドマップエディタ",
  "description": "Markdownの見出し構造をインタラクティブなマインドマップとして表示・編集するVS Code拡張機能",
  "version": "2.9.6",
  "publisher": "Hashi-Kazu",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hashi-Kazu/vscode-mindmap-editor"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#12121E",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization"],
  "keywords": ["markdown", "mindmap", "mind map", "editor", "visualization"],
  "activationEvents": ["onLanguage:markdown"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Markdown マインドマップエディタ",
      "properties": {
        "mindmap.followActiveEditor": {
          "type": "boolean",
          "default": true,
          "description": "アクティブなMarkdownエディタが切り替わったとき、マインドマップビューアの表示内容を自動でその.mdファイルに追従させる"
        }
      }
    },
    "commands": [
      {
        "command": "mindmap.openMindMap",
        "title": "マインドマップとして開く",
        "category": "Mind Map",
        "icon": {
          "light": "media/icon.png",
          "dark": "media/icon.png"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mindmap.openMindMap",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "mindmap.openMindMap",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mindmap.openMindMap",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "editorLangId == markdown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "npx vsce package",
    "pretest": "node esbuild.test.js",
    "test": "node --test \"dist-test/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
